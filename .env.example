# ─────────────────────────────────────────────
#  MatWerk Zenodo Portal  –  Environment Config
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Zenodo OAuth App credentials
# Register at: https://sandbox.zenodo.org/account/settings/applications/
ZENODO_CLIENT_ID=your_numeric_client_id
ZENODO_CLIENT_SECRET=your_client_secret_here

# Switch between sandbox and production:
ZENODO_BASE_URL=https://sandbox.zenodo.org

# ⚠️  CRITICAL: Must match EXACTLY what you put in Zenodo OAuth app Redirect URI field
# Since nginx proxies /auth → backend, use port 3000 (the frontend port)
OAUTH_REDIRECT_URI=http://127.0.0.1:3000/auth/callback

# Zenodo community
COMMUNITY_ID=nfdi-matwerk

# Secret key (generate: openssl rand -hex 32)
SECRET_KEY=changeme-replace-with-random-string

# App URLs
FRONTEND_URL=http://127.0.0.1:3000
VITE_API_URL=http://127.0.0.1:3000
